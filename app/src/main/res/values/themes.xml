<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.GrainCheck" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mint_green</item>
        <item name="colorOnPrimary">@color/charcoal</item>
        <item name="android:windowBackground">@color/pure_white</item>
        <item name="colorSurface">@color/pure_white</item>
    </style>

    <style name="Theme.GrainCheck" parent="Base.Theme.GrainCheck" />

    <!-- Pill-shaped Mint Button -->
    <style name="Widget.GrainCheck.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">32dp</item>
        <item name="backgroundTint">@color/mint_green</item>
        <item name="android:textColor">@color/charcoal</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Pale Mint Flat Card -->
    <style name="Widget.GrainCheck.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/pale_mint</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- Custom Input Style -->
    <style name="Widget.GrainCheck.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintTextColor">@color/charcoal</item>
        <item name="boxBackgroundColor">@android:color/transparent</item>
    </style>
</resources>
