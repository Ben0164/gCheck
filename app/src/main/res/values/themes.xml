<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.GrainCheck" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorError">@color/error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.GrainCheck" parent="Base.Theme.GrainCheck" />

    <!-- Display / titles → use sans-serif-medium (Material) -->
    <style name="TextAppearance.GrainCheck.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.GrainCheck.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.GrainCheck.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.GrainCheck.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="ThemeOverlay.GrainCheck.PrimaryButton" parent="">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
    </style>

    <style name="ThemeOverlay.GrainCheck.SecondaryButton" parent="">
        <item name="colorPrimary">@color/primary</item>
    </style>

    <style name="Widget.GrainCheck.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/button_corner</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.GrainCheck.Button" parent="Widget.GrainCheck.Button.Primary" />

    <style name="Widget.GrainCheck.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner</item>
        <item name="strokeColor">@color/outline</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.GrainCheck.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:layout_margin">@dimen/grid_1</item>
    </style>

    <style name="Widget.GrainCheck.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/card_corner</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.GrainCheck.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
        <item name="android:textColorHint">@color/on_surface_variant</item>
        <item name="startIconTint">@color/on_surface_variant</item>
        <item name="endIconTint">@color/on_surface_variant</item>
    </style>

    <style name="ShapeAppearance.GrainCheck.FAB" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">28dp</item>
    </style>
</resources>
