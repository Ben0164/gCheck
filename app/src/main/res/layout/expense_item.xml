<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_expense"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_expense_category_product"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seeds - NSIC Rc222"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textColor="@color/on_surface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_expense_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="1 bag × ₱100.00"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_expense_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱100.00"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/primary"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>