<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- 1. HEADER SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1F4D3A"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GCheck"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Production Ledger"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="#CCFFFFFF" />

        <!-- 2. TOGGLE BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/toggle_background"
            android:orientation="horizontal"
            android:padding="4dp">

            <TextView
                android:id="@+id/tv_tab_phases"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/active_tab_background"
                android:gravity="center"
                android:text="Phases"
                android:textColor="#1F4D3A"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tab_dashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Dashboard"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </LinearLayout>

    <!-- 3. PHASE LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_phases"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

</LinearLayout>