<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_no_batch"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_land_prep"
            app:tint="@color/gray_text"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/tv_error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/error_select_batch"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@color/gray_text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_batch_first"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Create New Batch" />
    </LinearLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/layout_dashboard_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/soft_gray">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_scrollFlags="scroll|exitUntilCollapsed">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_back_to_logbook"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:icon="@drawable/ic_arrow_back"
                            app:iconTint="@color/earth_green" />

                        <TextView
                            android:id="@+id/tv_ledger_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Production Ledger"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textStyle="bold"
                            android:textColor="@color/earth_green" />
                    </LinearLayout>

                    <!-- Phase Calculator Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tv_current_phase_display"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Current Phase: Auto calculating..."
                                    android:textStyle="bold"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_complete_batch"
                                    style="@style/Widget.Material3.Button.TonalButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="End Cycle"
                                    android:textSize="10sp"
                                    app:icon="@android:drawable/ic_menu_save"
                                    app:iconSize="14dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_phase_suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Smart suggestions will appear here."
                                android:textSize="12sp"
                                android:textColor="@color/gray_text" />

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/phase_progress_bar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:progress="0"
                                app:trackThickness="8dp"
                                app:trackCornerRadius="4dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_change_phase"
                                    style="@style/Widget.Material3.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Change Phase"
                                    android:textSize="11sp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_reset_auto"
                                    style="@style/Widget.Material3.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Use Auto Mode"
                                    android:textSize="11sp"
                                    android:visibility="gone" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Dashboard of Total Production Cost -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_cost_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/primary"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/tv_cost_display_label"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Cash Cost (Explicit Only)"
                                    android:textColor="#CCFFFFFF"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium" />
                                <TextView
                                    android:id="@+id/tv_batch_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_placeholder"
                                    android:textColor="#CCFFFFFF"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_total_expenses_all"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱0.00"
                                android:textColor="@android:color/white"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineLarge"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="8dp"
                                android:background="#33FFFFFF" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="💰 Breakeven"
                                        android:textColor="#CCFFFFFF"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/tv_breakeven_price"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="₱0.00/kg"
                                        android:textColor="@android:color/white"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tv_expected_yield"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 kg"
                                        android:textColor="#CCFFFFFF"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:id="@+id/tv_breakeven_hint"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/breakeven_hint"
                                        android:textColor="#99FFFFFF"
                                        android:textSize="10sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📈 Est. Profit"
                                        android:textColor="#CCFFFFFF"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/tv_est_profit"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="₱0.00"
                                        android:textColor="@android:color/white"
                                        android:textStyle="bold" />

                                    <EditText
                                        android:id="@+id/et_sell_price"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:background="@android:color/transparent"
                                        android:hint="Enter price"
                                        android:textColorHint="#99FFFFFF"
                                        android:textColor="@android:color/white"
                                        android:textSize="10sp"
                                        android:inputType="numberDecimal" />
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="8dp"
                                android:background="#33FFFFFF" />

                            <!-- Profit Mode Toggle Area -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/label_owner_labor"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp" />

                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/switch_profit_mode"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:thumbTint="@color/white"
                                    app:trackTint="@color/soft_gray" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layout_implicit_summary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="4dp"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/tv_total_implicit_cost_label"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/est_labor_cost_label"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tv_total_implicit_cost"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₱0.00"
                                    android:textColor="@android:color/white"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="8dp"
                                android:background="#33FFFFFF" />

                            <TextView
                                android:id="@+id/tv_production_cost_subtotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/production_cost_label"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_internal_transport"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/internal_transport_label"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_transport_to_buyer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/transport_to_buyer_label"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_grand_total_all"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/total_cost_all_label"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:textSize="12sp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- FARMING PHASES GRID -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Production Phases"
                        android:textStyle="bold"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                        android:textColor="@color/earth_green" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:columnCount="3">
                        <LinearLayout android:id="@+id/phase_land_prep" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                            <com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" android:backgroundTint="@color/primary_container"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_land_prep" app:tint="@color/primary" android:contentDescription="Land Preparation"/></com.google.android.material.card.MaterialCardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Land Prep" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/phase_crop_est" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                            <com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" android:backgroundTint="@color/primary_container"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_crop_establishment" app:tint="@color/primary" android:contentDescription="Crop Establishment"/></com.google.android.material.card.MaterialCardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Planting" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/phase_crop_mgmt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                            <com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" android:backgroundTint="@color/primary_container"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_crop_management" app:tint="@color/primary" android:contentDescription="Crop Management"/></com.google.android.material.card.MaterialCardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Management" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/phase_monitoring" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                            <com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" android:backgroundTint="@color/primary_container"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_monitoring" app:tint="@color/primary" android:contentDescription="Monitoring"/></com.google.android.material.card.MaterialCardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Monitoring" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/phase_harvest" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                            <com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" android:backgroundTint="@color/primary_container"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_harvesting" app:tint="@color/primary" android:contentDescription="Harvesting"/></com.google.android.material.card.MaterialCardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Harvesting" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/phase_post_harvest" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                            <com.google.android.material.card.MaterialCardView android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" android:backgroundTint="@color/primary_container"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_post_harvest" app:tint="@color/primary" android:contentDescription="Post Harvest"/></com.google.android.material.card.MaterialCardView>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Post-Harvest" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>

            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_expenses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            android:paddingBottom="16dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>
