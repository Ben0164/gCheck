<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.GrainCheck.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/view_indicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/soft_green" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_inbox_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Update"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_inbox_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Your grain analysis is complete and ready."
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/gray_text" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:padding="16dp"
            android:text="10:30 AM"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/gray_text" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>